{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "content-blog": {
      "projectType": "application",
      "schematics": {},
      "root": "",
      "sourceRoot": "ng-src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:application",
          "options": {
            "outputPath": "dist",
            "index": "ng-src/index.html",
            "browser": "ng-src/main.ts",
            "polyfills": ["zone.js"],
            "tsConfig": "tsconfig.app.json",
            "assets": [
              { "glob": "**/*", "input": "src", "output": "src" },
              { "glob": "structure.json", "input": ".", "output": "" },
              { "glob": "CNAME", "input": ".", "output": "" },
              { "glob": "favicon.svg", "input": ".", "output": "" }
            ],
            "styles": [
              "node_modules/bootstrap/dist/css/bootstrap.min.css",
              "ng-src/styles.scss"
            ],
            "scripts": [
              "node_modules/bootstrap/dist/js/bootstrap.bundle.min.js"
            ]
          },
          "configurations": {
            "production": {
              "budgets": [
                { "type": "initial", "maximumWarning": "500kB", "maximumError": "2MB" },
                { "type": "anyComponentStyle", "maximumWarning": "4kB", "maximumError": "8kB" }
              ],
              "outputHashing": "all",
              "optimization": { "fonts": { "inline": false } }
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "configurations": {
            "production": { "buildTarget": "content-blog:build:production" },
            "development": { "buildTarget": "content-blog:build:development" }
          },
          "defaultConfiguration": "development"
        }
      }
    }
  }
}
